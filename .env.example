# Configuración para el envío de correos electrónicos
EMAIL_HOST=
EMAIL_PORT=
EMAIL_SECURE=true
EMAIL_USER=
EMAIL_PASS=

# Google Maps API Keys
# Frontend (solo Places JS en navegador). Restringir por HTTP referrer y APIs permitidas.
VITE_GOOGLE_MAPS_API_KEY=
# Backend (Geocoding/Routes desde servidor). No se expone al navegador.
GOOGLE_MAPS_API_KEY=
